{
  "exports": {
    ".": "./pragma/module.ts",
    "./element": "./element/module.ts",
    "./helpers": "./helpers/module.ts",
    "./html": "./html/module.ts"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 80,
    "semiColons": true,
    "singleQuote": false
  },
  "imports": {
    "@cutout/jsx/element": "./element",
    "@cutout/jsx/helpers": "./helpers",
    "@cutout/jsx/html": "./html"
  },
  "lint": {
    "plugins": [
      "jsr:@ayk/lint-import-order"
    ]
  },
  "name": "@cutout/jsx",
  "version": "0.0.0-alpha.0"
}
